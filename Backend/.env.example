# ── Deepgram STT ───────────────────────────────────────
DEEPGRAM_API_KEY=1b97c02e12d4c221c6b6d285bb607ab50fa2c270

# ── Google Cloud TTS ───────────────────────────────────
# Path to your Google service account JSON file
