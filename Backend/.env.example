# ── Infrastructure ──────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./voice_agent.db

# ── App ────────────────────────────────────────────────
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Latency Targets (ms) ───────────────────────────────
STT_TARGET_MS=120
LLM_TARGET_MS=200
TTS_TARGET_MS=100
TOTAL_TARGET_MS=450
